# Firebase web app (Project settings → Your apps → SDK snippet — config)
VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Trip window for header countdown (local calendar days; ISO date YYYY-MM-DD)
# July 2–5, 2026: arrival Jul 2 through pack-out Jul 5 (inclusive).
VITE_TRIP_START=2026-07-02
VITE_TRIP_END=2026-07-05

# Optional: base path for static hosting (default "/"). GitHub Pages example: "/july4-camping-shopping-list/"
# VITE_BASE_PATH=/
